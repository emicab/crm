generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Brand {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  logoUrl   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  logoUrl   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
  promotionConditions PromotionCondition[]
}

model Product {
  id            Int            @id @default(autoincrement())
  name          String
  sku           String?        @unique
  description   String?
  pricePurchase Decimal
  priceSale     Decimal
  quantityStock Float
  stockMinAlert Float?
  unitType      String?  // null=sin especificar, UNIT, WEIGHT, VOLUME
  brandId       Int
  categoryId    Int
  supplierId    Int?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  category      Category       @relation(fields: [categoryId], references: [id])
  brand         Brand          @relation(fields: [brandId], references: [id])
  supplier      Supplier?      @relation(fields: [supplierId], references: [id])
  SaleItem         SaleItem[]
  purchaseItems    PurchaseItem[]
  comboItems       ComboItem[]
  promotionConditions PromotionCondition[]
}

model Client {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String?
  email     String?  @unique
  phone     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Sale      Sale[]

  @@index([firstName, lastName])
}

model Seller {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  email     String?  @unique
  phone     String?
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  sales        Sale[]
  cashRegisters CashRegister[]
}

model Sale {
  id                  Int           @id @default(autoincrement())
  saleDate            DateTime      @default(now())
  totalAmount         Decimal
  paymentType         PaymentType
  notes               String?
  clientId            Int?
  sellerId            Int
  cashRegisterId      Int?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  discountCodeApplied String?
  promotionsApplied   String?       // JSON: [{promotionId, name, type, discountAmount}]
  seller              Seller        @relation(fields: [sellerId], references: [id])
  client              Client?       @relation(fields: [clientId], references: [id])
  cashRegister        CashRegister? @relation(fields: [cashRegisterId], references: [id])
  items               SaleItem[]
}

model SaleItem {
  id                  Int     @id @default(autoincrement())
  quantity            Float
  priceAtSale         Decimal
  purchasePriceAtSale Decimal
  saleId              Int
  productId           Int
  product             Product @relation(fields: [productId], references: [id])
  sale                Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

model Expense {
  id          Int         @id @default(autoincrement())
  expenseDate DateTime    @default(now())
  description String
  amount      Decimal
  category    String
  paymentType PaymentType
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Combo {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  price       Decimal   // Precio fijo del combo
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  items       ComboItem[]
}

model ComboItem {
  id          Int      @id @default(autoincrement())
  comboId     Int
  productId   Int
  quantity    Float    @default(1)
  customPrice Decimal?
  combo   Combo   @relation(fields: [comboId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model Promotion {
  id             Int                   @id @default(autoincrement())
  name           String
  description    String?
  type           String                // BUY_X_GET_Y, SET_DISCOUNT, THRESHOLD
  status         String                @default("ACTIVE")
  discountType   String                // PERCENTAGE, FIXED_AMOUNT
  discountValue  Decimal               // 10 (10%) o 500 ($500)
  minQuantity    Int?                  // Para THRESHOLD/BUY_X_GET_Y
  maxDiscountQty Int?                  // Para BUY_X_GET_Y: máx unidades con descuento
  priority       Int                   @default(0)
  startDate      DateTime?
  endDate        DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  conditions     PromotionCondition[]
}

model PromotionCondition {
  id          Int       @id @default(autoincrement())
  promotionId Int
  productId   Int?
  categoryId  Int?
  minQuantity Int       @default(1)

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  product   Product?  @relation(fields: [productId], references: [id])
  category  Category? @relation(fields: [categoryId], references: [id])
}

model Supplier {
  id            Int     @id @default(autoincrement())
  name          String  @unique
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  notes         String?

  purchases Purchase[]
  products  Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Purchase {
  id            Int            @id @default(autoincrement())
  purchaseDate  DateTime       @default(now())
  totalAmount   Decimal // Costo total de la compra
  status        PurchaseStatus @default(PENDING) // Estado de la compra
  paymentType   PaymentType? // Medio de pago (efectivo, transferencia, tarjeta, QR)
  invoiceNumber String? // Número de factura del proveedor (opcional)
  notes         String?

  supplierId Int
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  items PurchaseItem[] // Los productos comprados en esta transacción

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PurchaseItem {
  id                Int     @id @default(autoincrement())
  quantity          Float   // Cantidad pedida
  quantityReceived  Float?  // Cantidad realmente recibida (null si aún no recibido)
  purchasePrice     Decimal // Costo por unidad en esta compra específica

  purchaseId Int
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  productId Int
  product   Product @relation(fields: [productId], references: [id])
}

enum PaymentType {
  CASH
  TRANSFER
  CARD
  QR
  OTHER
}

enum PurchaseStatus {
  PENDING
  ORDERED
  RECEIVED
  CANCELLED
}

model DiscountCode {
  id              Int       @id @default(autoincrement())
  code            String    @unique
  discountPercent Decimal // Porcentaje de descuento (ej: 10.0)
  validFrom       DateTime?
  validUntil      DateTime?
  maxUses         Int? // Límite de usos (null = ilimitado)
  currentUses     Int       @default(0)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model CashRegister {
  id              Int       @id @default(autoincrement())
  openDate        DateTime  @default(now())
  closeDate       DateTime?
  initialBalance  Decimal   @default(0)
  expectedBalance Decimal?
  actualBalance   Decimal?
  difference      Decimal?
  status          String    @default("OPEN")
  notes           String?
  sellerId        Int?
  seller          Seller?   @relation(fields: [sellerId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  movements       CashMovement[]
  sales           Sale[]
}

model CashMovement {
  id              Int       @id @default(autoincrement())
  cashRegisterId  Int
  type            String    // SALE, EXPENSE, WITHDRAWAL, DEPOSIT, ADJUSTMENT
  paymentType     String?   // CASH, TRANSFER, CARD, QR, OTHER
  sourceId        Int?      // ID de la venta/gasto relacionado
  amount          Decimal   // Positivo = ingreso, Negativo = egreso
  description     String?
  createdAt       DateTime  @default(now())
  cashRegister    CashRegister @relation(fields: [cashRegisterId], references: [id])
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}
