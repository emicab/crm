{
  "name": "clinpos",
  "version": "2.0.0",
  "description": "ClinPOS By EmiDev",
  "author": "Emiliano Cabanillas",
  "private": true,
  "main": "electron/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/emicab/crm.git"
  },
  "scripts": {
    "dev": "concurrently \"npm:dev:next\" \"npm:dev:electron\"",
    "dev:next": "next dev --hostname 0.0.0.0",
    "dev:electron": "wait-on http://localhost:3000 && electron .",
    "build": "npx prisma generate && node scripts/migrate-template.js && next build && electron-builder",
    "publish": "npx prisma generate && node scripts/migrate-template.js && next build && electron-builder --win --x64 --publish always"
  },
  "dependencies": {
    "@prisma/client": "^6.4.0",
    "@supabase/supabase-js": "^2.110.2",
    "class-variance-authority": "^0.7.1",
    "driver.js": "^1.6.0",
    "electron-store": "^7.0.3",
    "electron-updater": "^6.6.2",
    "lucide-react": "^0.511.0",
    "motion": "^12.16.0",
    "next": "15.3.3",
    "node-machine-id": "^1.1.12",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.5.2",
    "recharts": "^2.15.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.2",
    "electron": "^36.3.2",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "15.3.3",
    "prisma": "^6.4.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.emidev.crm",
    "productName": "ClinPOS",
    "publish": {
      "provider": "github",
      "owner": "emicab",
      "repo": "crm"
    },
    "asar": false,
    "files": [
      "package.json",
      {
        "from": "electron",
        "to": "electron"
      },
      {
        "from": "public",
        "to": "public"
      },
      {
        "from": ".next/standalone",
        "to": ".next/standalone"
      },
      {
        "from": ".next/static",
        "to": ".next/standalone/.next/static"
      },
      {
        "from": "node_modules/.prisma",
        "to": "node_modules/.prisma"
      },
      {
        "from": "node_modules/@prisma/client/libquery_engine-windows.dll.node",
        "to": "node_modules/@prisma/client/libquery_engine-windows.dll.node"
      },
      {
        "from": "node_modules/prisma",
        "to": "node_modules/prisma"
      },
      {
        "from": "prisma/migrations",
        "to": "prisma/migrations"
      }
    ],
    "extraFiles": [
      {
        "from": ".next/standalone/node_modules/.prisma",
        "to": "resources/app/.next/standalone/node_modules/.prisma"
      },
      {
        "from": ".next/standalone/node_modules/@prisma",
        "to": "resources/app/.next/standalone/node_modules/@prisma"
      }
    ],
    "extraResources": [
      {
        "from": "prisma/crm_template.db",
        "to": "crm_template.db"
      },
      {
        "from": "prisma/schema.prisma",
        "to": "schema.prisma"
      }
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist_electron"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
