{
  "name": "clinpos",
  "version": "1.5.5",
  "description": "ClinPOS By EmiDev",
  "author": "Emiliano Cabanillas",
  "private": true,
  "main": "electron/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/emicab/crm.git"
  },
  "scripts": {
    "dev": "concurrently \"npm:dev:next\" \"npm:dev:electron\"",
    "dev:next": "next dev --hostname 0.0.0.0",
    "dev:electron": "wait-on http://localhost:3000 && electron .",
    "dev:tauri": "powershell -Command \"$env:PATH = \\\"$env:USERPROFILE\\.cargo\\bin;$env:PATH\\\"; npx @tauri-apps/cli dev\"",
    "build:next": "powershell -Command \"if (Test-Path .next) { Remove-Item -Recurse -Force .next }; if (Test-Path dist_tauri) { Remove-Item -Recurse -Force dist_tauri }\"; npx prisma generate && node scripts/migrate-template.js && next build && powershell -Command \"New-Item -ItemType Directory -Path dist_tauri; Copy-Item -Recurse public/* dist_tauri/; New-Item -ItemType Directory -Path .next/standalone/.next -ErrorAction SilentlyContinue; Copy-Item -Recurse .next/static .next/standalone/.next/static; Copy-Item -Recurse public .next/standalone/public; Copy-Item (Get-Command node).Source .next/standalone/node.exe\"",
    "build": "npm run build:next && npx electron scripts/compile-bytecode.js && electron-builder",
    "build:tauri": "powershell -Command \"$env:PATH = \\\"$env:USERPROFILE\\.cargo\\bin;$env:PATH\\\"; npx @tauri-apps/cli build\"",
    "publish": "echo 'Para publicar una release, simplemente crea un tag en git (ej. git tag v1.5.6) y haz push (git push origin v1.5.6). GitHub Actions se encargará de compilar y subir el instalador a Releases.' && exit 1"
  },
  "dependencies": {
    "@afipsdk/afip.js": "^1.2.3",
    "@prisma/client": "^6.4.0",
    "@supabase/supabase-js": "^2.110.2",
    "@tauri-apps/api": "^2.2.0",
    "bytenode": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "driver.js": "^1.6.0",
    "electron-store": "^7.0.3",
    "electron-updater": "^6.6.2",
    "lucide-react": "^0.511.0",
    "mercadopago": "^3.2.0",
    "motion": "^12.16.0",
    "next": "15.3.3",
    "node-forge": "^1.4.0",
    "node-machine-id": "^1.1.12",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.5.2",
    "recharts": "^2.15.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/node-forge": "^1.3.14",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.2",
    "@tauri-apps/cli": "^2.2.0",
    "electron": "^36.3.2",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "15.3.3",
    "prisma": "^6.4.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.emidev.crm",
    "productName": "ClinPOS",
    "publish": {
      "provider": "github",
      "owner": "emicab",
      "repo": "crm"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/.prisma",
      "node_modules/@prisma"
    ],
    "afterPack": "scripts/after-pack.js",
    "files": [
      "package.json",
      {
        "from": "electron-dist",
        "to": "electron"
      },
      {
        "from": "public",
        "to": "public"
      },
      "!node_modules/prisma/**/*",
      "!node_modules/@next/swc*/**/*",
      "!node_modules/typescript/**/*",
      "!node_modules/@types/**/*",
      "!node_modules/eslint*/**/*",
      "!node_modules/tailwindcss/**/*",
      "!node_modules/@tailwindcss/**/*",
      "!node_modules/postcss/**/*"
    ],
    "extraFiles": [
      {
        "from": ".next/standalone",
        "to": "resources/standalone",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".next/static",
        "to": "resources/standalone/.next/static",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "public",
        "to": "resources/standalone/public",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraResources": [
      {
        "from": "prisma/crm_template.db",
        "to": "crm_template.db"
      },
      {
        "from": "prisma/schema.prisma",
        "to": "schema.prisma"
      }
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist_electron"
    },
    "win": {
      "target": "nsis",
      "compression": "maximum"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
