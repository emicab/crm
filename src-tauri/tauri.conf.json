{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClinPOS",
  "version": "1.5.7",
  "identifier": "com.emidev.clinpos",
  "build": {
    "frontendDist": "../dist_tauri",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev:next",
    "beforeBuildCommand": "npm run build:next"
  },
  "app": {
    "windows": [
      {
        "title": "ClinPOS",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../.next/standalone/**/*",
      "../prisma/crm_template.db",
      "../prisma/schema.prisma"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
